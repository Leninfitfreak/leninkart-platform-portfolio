@startuml
left to right direction
skinparam shadowing false
skinparam backgroundColor #ffffff
skinparam defaultFontName Segoe UI
skinparam dpi 220
skinparam linetype ortho
skinparam ArrowColor #4B5563
skinparam ArrowThickness 2
skinparam ranksep 32
skinparam nodesep 18
skinparam state {
  FontColor #0F172A
  BorderColor #D7E0EF
  BorderThickness 1.5
  RoundCorner 20
  BackgroundColor white
  StartColor white
  EndColor white
}
skinparam note {
  BackgroundColor #F8FAFC
  BorderColor #D7E0EF
  FontColor #475569
}
skinparam title {
  FontSize 24
  FontColor #0F172A
}
scale max 4200 width
title LeninKart Dev Platform Runtime View

state "<size:18><b>Jira</b></size>\n<img:modern-assets/jira.svg{scale=0.17}>\nDeployment request" as JIRA #EEF2FF
state "<size:18><b>GitHub Actions</b></size>\n<img:modern-assets/githubactions.svg{scale=0.17}>\nworkflow_dispatch" as GHA #EEF2FF
state "<size:18><b>Self-hosted Runner</b></size>\nWindows host\nleninkart-runner" as RUNNER #EEF2FF
state "<size:18><b>deployment-poc</b></size>\nControl plane\nversion resolution\nJira updates\nlock + rollback logic" as POC #F3E8FF
state "<size:18><b>leninkart-infra</b></size>\nDesired state repo\nvalues-dev.yaml update" as INFRA #FFEDD5
state "<size:18><b>ArgoCD</b></size>\n<img:modern-assets/argo.svg{scale=0.17}>\nSync + reconcile" as ARGO #FED7AA
state "<size:18><b>k3d-leninkart-dev</b></size>\n<img:modern-assets/kubernetes.svg{scale=0.17}>\nIngress\nfrontend\nproduct-service\norder-service\npostgres\nexternal-secrets" as RUN #DCFCE7
state "<size:18><b>Vault</b></size>\nSecret source\nExternal Secrets target" as VAULT #FFF1F2
state "<size:18><b>project-validation</b></size>\nGitHub proof\nGitOps proof\nArgoCD proof\napplication proof\nVault proof\nKafka proof" as VAL #F3E8FF
state "<size:18><b>Observability Stack</b></size>\n<img:modern-assets/prometheus.svg{scale=0.14}> <img:modern-assets/grafana.svg{scale=0.14}>\n<img:modern-assets/loki.png{scale=0.07}> <img:modern-assets/tempo.png{scale=0.07}>\n<img:modern-assets/apachekafka.svg{scale=0.14}>\nPrometheus | Grafana | Loki | Tempo | Kafka metrics" as OBS #DBEAFE
state "<size:18><b>Auto Rollback</b></size>\nValidation failure\nrestore previous stable revision\nGitOps rollback commit" as RB #FEE2E2

JIRA --> GHA
GHA --> RUNNER
RUNNER --> POC
POC --> INFRA
INFRA --> ARGO
ARGO --> RUN
RUN --> VAL
RUN --> OBS
RUN --> VAULT
OBS --> VAL : proof inputs
VAL -[#B45309,dashed]-> RB : verification failure
RB -[#B45309,dashed]-> POC : rollback decision
RB -[#B45309,dashed]-> INFRA : restore stable values
INFRA -[#B45309,dashed]-> ARGO : rollback commit
POC --> JIRA : progress + final status
RB -[#B45309,dashed]-> JIRA : rolled_back

note bottom of RUN
Single dev runtime environment with user traffic, services, data, and secret consumption.
end note

note bottom of OBS
Observability is used for both monitoring and validation proof.
end note

note bottom of VAL
Validation is independent of CI/CD and verifies the full delivery chain.
end note

note top of POC
GitOps is the only deployment write path into the cluster.
end note
@enduml
